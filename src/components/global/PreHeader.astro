---
import { useTranslations, getAlternateLangPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
  currentPage: string;
}

const { lang, currentPage } = Astro.props;
const t = useTranslations(lang);
const altPath = getAlternateLangPath(lang, currentPage);
---

<div class="preheader">
  <div class="container preheader__inner">
    <!-- Logo FV -->
    <a href={lang === 'es' ? '/' : '/en/'} class="preheader__logo" aria-label="Francisco Vela PF - Inicio">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 56 40" width="56" height="40" aria-hidden="true">
        <text x="0" y="34" font-family="Arial Black, Arial" font-size="38" font-weight="900" fill="#FFFFFF" letter-spacing="-2">F</text>
        <text x="22" y="34" font-family="Arial Black, Arial" font-size="38" font-weight="900" fill="#A3E635" letter-spacing="-2">V</text>
      </svg>
      <span class="preheader__logo-text">
        <span class="preheader__logo-name">FRANCISCO</span>
        <span class="preheader__logo-name">VELA</span>
      </span>
    </a>

    <div class="preheader__right">
      <!-- Redes sociales -->
      <div class="preheader__social">
        <a
          href="https://www.instagram.com/franciscovelapf"
          target="_blank"
          rel="noopener noreferrer"
          class="preheader__social-link"
          aria-label="Instagram de Francisco Vela"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          <span class="preheader__social-label">Instagram</span>
        </a>
        <a
          href="https://x.com/willyvelapf"
          target="_blank"
          rel="noopener noreferrer"
          class="preheader__social-link"
          aria-label="Twitter / X de Francisco Vela"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.741l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <span class="preheader__social-label">Twitter</span>
        </a>
      </div>

      <!-- Separador -->
      <span class="preheader__sep" aria-hidden="true"></span>

      <!-- CV -->
      <a href="/cv-francisco-vela-es.pdf" target="_blank" rel="noopener" class="preheader__cv">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
        </svg>
        {t('preheader.cv')}
      </a>

      <!-- Separador -->
      <span class="preheader__sep" aria-hidden="true"></span>

      <!-- Selector de idioma -->
      <div class="preheader__lang">
        <a
          href={lang === 'en' ? altPath : currentPage}
          class={`preheader__lang-btn ${lang === 'es' ? 'is-active' : ''}`}
          hreflang="es"
          aria-label="Ver en español"
        >
          <!-- Bandera España -->
          <svg class="preheader__flag" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14" aria-hidden="true">
            <rect width="20" height="14" rx="2" fill="#c60b1e"/>
            <rect y="3.5" width="20" height="7" fill="#f1bf00"/>
          </svg>
          <span>ES</span>
        </a>
        <span class="preheader__lang-div" aria-hidden="true">/</span>
        <a
          href={lang === 'es' ? altPath : currentPage}
          class={`preheader__lang-btn ${lang === 'en' ? 'is-active' : ''}`}
          hreflang="en"
          aria-label="View in English"
        >
          <!-- Bandera Reino Unido -->
          <svg class="preheader__flag" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14" aria-hidden="true">
            <rect width="20" height="14" rx="2" fill="#012169"/>
            <path d="M0 0l20 14M20 0L0 14" stroke="#fff" stroke-width="3"/>
            <path d="M0 0l20 14M20 0L0 14" stroke="#C8102E" stroke-width="1.8"/>
            <path d="M10 0v14M0 7h20" stroke="#fff" stroke-width="4.5"/>
            <path d="M10 0v14M0 7h20" stroke="#C8102E" stroke-width="2.8"/>
          </svg>
          <span>EN</span>
        </a>
      </div>
    </div>
  </div>
</div>

<style>
.preheader {
  background-color: var(--black-soft);
  border-bottom: 1px solid var(--black-border);
  height: var(--preheader-h);
  position: sticky;
  top: 0;
  z-index: 1000;
}

.preheader__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  gap: var(--space-4);
}

/* Logo */
.preheader__logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  transition: opacity var(--transition-fast);
  flex-shrink: 0;
}
.preheader__logo:hover { opacity: 0.85; }

.preheader__logo-text {
  display: flex;
  flex-direction: column;
  line-height: 1.1;
}
.preheader__logo-name {
  font-family: var(--font-body);
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--white);
  text-transform: uppercase;
}
/* Right side */
.preheader__right {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

/* Social */
.preheader__social {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}
.preheader__social-link {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  color: var(--gray-400);
  font-size: var(--text-xs);
  font-weight: 500;
  transition: color var(--transition-fast);
}
.preheader__social-link:hover { color: var(--lime); }
.preheader__social-label {
  display: none;
}

/* Separador */
.preheader__sep {
  display: block;
  width: 1px;
  height: 16px;
  background: var(--gray-700);
}

/* CV */
.preheader__cv {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  color: var(--gray-400);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: color var(--transition-fast);
}
.preheader__cv:hover { color: var(--lime); }

/* Lang */
.preheader__lang {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}
.preheader__lang-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--gray-500);
  transition: color var(--transition-fast);
}
.preheader__lang-btn:hover,
.preheader__lang-btn.is-active {
  color: var(--white);
}
.preheader__lang-btn.is-active {
  color: var(--lime);
}
.preheader__lang-div {
  color: var(--gray-700);
  font-size: var(--text-xs);
}
.preheader__flag {
  width: 20px;
  height: 14px;
  border-radius: 2px;
  flex-shrink: 0;
  box-shadow: 0 0 0 1px rgba(255,255,255,0.1);
}

/* Mobile */
@media (max-width: 480px) {
  .preheader__logo-text { display: none; }
  .preheader__cv { display: none; }
  .preheader__sep:first-of-type { display: none; }
}

@media (min-width: 768px) {
  .preheader__social-label { display: inline; }
  .preheader__social { gap: var(--space-4); }
}
</style>
