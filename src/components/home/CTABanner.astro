---
import { useTranslations, pageRoutes } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="cta-banner">
  <div class="cta-banner__bg">
    <img
      src="/images/hero/asesoramiento-bg.jpg"
      alt=""
      aria-hidden="true"
      width="1400"
      height="500"
      loading="lazy"
      class="cta-banner__bg-img"
    />
    <div class="cta-banner__overlay"></div>
  </div>
  <div class="container cta-banner__content animate">
    <p class="cta-banner__tagline">{lang === 'es' ? 'Asesoramiento' : 'Coaching'}</p>
    <h2 class="cta-banner__title">
      {t('home.cta_banner.title_1')}<br />
      <span class="cta-banner__title--lime">{t('home.cta_banner.title_2')}</span><br />
      {t('home.cta_banner.title_3')}
    </h2>
    <p class="cta-banner__subtitle">{t('home.cta_banner.subtitle')}</p>
    <a href={pageRoutes.contact[lang]} class="btn btn--primary cta-banner__btn">
      {t('home.cta_banner.cta')}
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
  </div>
</section>

<style>
.cta-banner {
  position: relative;
  overflow: hidden;
  min-height: 420px;
  display: flex;
  align-items: center;
}

.cta-banner__bg {
  position: absolute;
  inset: 0;
}
.cta-banner__bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 25%;
}
.cta-banner__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(10,10,10,0.92) 0%, rgba(10,10,10,0.7) 60%, rgba(10,10,10,0.5) 100%);
}

.cta-banner__content {
  position: relative;
  z-index: 1;
  padding-block: var(--space-16);
}

.cta-banner__tagline {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--lime);
  margin-bottom: var(--space-4);
}

.cta-banner__title {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  color: var(--white);
  line-height: 1;
  margin-bottom: var(--space-5);
}
.cta-banner__title--lime { color: var(--lime); }

.cta-banner__subtitle {
  font-size: var(--text-base);
  color: var(--gray-300);
  max-width: 440px;
  line-height: 1.7;
  margin-bottom: var(--space-8);
}

.cta-banner__btn {
  font-size: var(--text-sm);
}

@media (max-width: 768px) {
  .cta-banner__overlay {
    background: rgba(10,10,10,0.88);
  }
  .cta-banner__title { font-size: var(--text-3xl); }
}
</style>
