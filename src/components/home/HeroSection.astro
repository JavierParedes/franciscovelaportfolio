---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero">
  <!-- Foto de fondo -->
  <div class="hero__bg">
    <img
      src="/images/hero/hero-main.jpg"
      alt="Francisco Vela, Preparador Físico de Fútbol"
      class="hero__bg-img"
      width="1400"
      height="900"
      fetchpriority="high"
      loading="eager"
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="container hero__content">
    <div class="hero__text">
      <p class="hero__tagline animate animate--delay-1">{t('home.hero.tagline')}</p>
      <h1 class="hero__headline animate animate--delay-2">
        <span class="hero__headline-line">{t('home.hero.headline_1')}</span>
        <span class="hero__headline-line hero__headline-line--lime">{t('home.hero.headline_2')}</span>
      </h1>
      <p class="hero__subtitle animate animate--delay-3">{t('home.hero.subtitle')}</p>
      <div class="hero__actions animate animate--delay-4">
        <a href="#bio" class="btn btn--primary">
          {t('home.hero.cta')}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="hero__stats animate">
    <div class="container">
      <div class="hero__stats-grid">
        <div class="hero__stat">
          <span class="hero__stat-num" data-target="10">+10</span>
          <span class="hero__stat-label">{t('home.stats.years_label')}</span>
        </div>
        <div class="hero__stat-sep" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">5+</span>
          <span class="hero__stat-label">{t('home.stats.teams_label')}</span>
        </div>
        <div class="hero__stat-sep" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">200+</span>
          <span class="hero__stat-label">{t('home.stats.players_label')}</span>
        </div>
        <div class="hero__stat-sep" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num hero__stat-num--lime">100%</span>
          <span class="hero__stat-label">{t('home.stats.commitment_label')}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-line"></span>
    <span class="hero__scroll-text">{t('home.hero.scroll')}</span>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

/* Fondo */
.hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero__bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: left center;
}
.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    100deg,
    rgba(10,10,10,0.95) 0%,
    rgba(10,10,10,0.85) 35%,
    rgba(10,10,10,0.40) 60%,
    rgba(10,10,10,0.15) 100%
  );
}

/* Contenido */
.hero__content {
  position: relative;
  z-index: 1;
  padding-top: var(--space-20);
  padding-bottom: var(--space-24);
}

.hero__text {
  max-width: 700px;
}

.hero__tagline {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--lime);
  margin-bottom: var(--space-4);
}

.hero__headline {
  font-family: var(--font-display);
  font-size: var(--text-hero);
  line-height: 0.92;
  color: var(--white);
  margin-bottom: var(--space-6);
  letter-spacing: 0.01em;
}
.hero__headline-line {
  display: block;
}
.hero__headline-line--lime {
  color: var(--lime);
}

.hero__subtitle {
  font-size: var(--text-base);
  color: var(--gray-300);
  max-width: 460px;
  line-height: 1.7;
  margin-bottom: var(--space-10);
}

.hero__actions {
  display: flex;
  gap: var(--space-4);
  flex-wrap: wrap;
}

/* Stats bar */
.hero__stats {
  position: relative;
  z-index: 1;
  background: rgba(17, 17, 17, 0.92);
  backdrop-filter: blur(8px);
  border-top: 1px solid var(--black-border);
  margin-top: auto;
}

.hero__stats-grid {
  display: flex;
  align-items: center;
  padding-block: var(--space-6);
  gap: 0;
}

.hero__stat {
  flex: 1;
  text-align: center;
  padding-inline: var(--space-4);
}

.hero__stat-num {
  display: block;
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  color: var(--white);
  line-height: 1;
  margin-bottom: var(--space-1);
}
.hero__stat-num--lime { color: var(--lime); }

.hero__stat-label {
  display: block;
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray-500);
}

.hero__stat-sep {
  width: 1px;
  height: 40px;
  background: var(--black-border);
  flex-shrink: 0;
}

/* Scroll */
.hero__scroll {
  position: absolute;
  bottom: 120px;
  left: clamp(1rem, 5vw, 3rem);
  display: flex;
  align-items: center;
  gap: var(--space-3);
  z-index: 1;
}
.hero__scroll-line {
  display: block;
  width: 40px;
  height: 1px;
  background: var(--lime);
  animation: scrollPulse 2s ease-in-out infinite;
}
.hero__scroll-text {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gray-500);
}

@keyframes scrollPulse {
  0%, 100% { width: 40px; opacity: 1; }
  50% { width: 60px; opacity: 0.5; }
}

/* Responsive */
@media (max-width: 480px) {
  .hero__headline { font-size: clamp(2.8rem, 14vw, 4rem); }
  .hero__stats-grid { flex-wrap: wrap; gap: var(--space-4); }
  .hero__stat { flex: 0 0 calc(50% - var(--space-4)); }
  .hero__stat-sep { display: none; }
  .hero__scroll { display: none; }
}

@media (max-width: 768px) {
  .hero__bg-img {
    object-position: 48% center;
  }
  .hero__overlay {
    background: linear-gradient(
      180deg,
      rgba(10,10,10,0.82) 0%,
      rgba(10,10,10,0.55) 60%,
      rgba(10,10,10,0.75) 100%
    );
  }
  .hero__content { padding-top: var(--space-12); }
}
</style>
