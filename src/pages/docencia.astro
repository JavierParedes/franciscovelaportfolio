---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
const teaching = t('teaching') as any[];

const excludePhotos = new Set([1, 2, 4, 19, 20, 22, 26, 30]);
const formacionPhotos = Array.from({ length: 30 }, (_, i) => i + 1)
  .filter(n => !excludePhotos.has(n))
  .map(i => ({
    src: `/images/formacion/formacion-${String(i).padStart(3, '0')}.jpg`,
    alt: `Formación Francisco Vela - imagen ${i}`
  }));

const institutions = [
  { name: 'Florida Global University', logo: '/images/logos/florida-global.png', url: '#' },
  { name: 'APREFUCO', logo: '/images/logos/aprefuco.png', url: '#' },
  { name: 'Federación Extremeña de Fútbol', logo: '/images/logos/fef.png', url: '#' },
  { name: 'Universidad San Buenaventura Cali', logo: '/images/logos/usbcali.png', url: '#' },
];
---

<BaseLayout
  lang={lang}
  currentPage="/docencia"
  title={t('docencia.meta_title') as string}
  description={t('docencia.meta_description') as string}
  image="/images/formacion/docencia-hero.jpg"
>
  <!-- Hero de página -->
  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="/images/formacion/docencia-hero.jpg" alt="" aria-hidden="true" width="1400" height="500" loading="eager" class="page-hero__img" />
      <div class="page-hero__overlay"></div>
    </div>
    <div class="container page-hero__content animate">
      <span class="section-tagline">{t('docencia.tagline')}</span>
      <h1 class="page-hero__title">
        {t('docencia.title_1')}<br /><span>{t('docencia.title_2')}</span>
      </h1>
    </div>
  </section>

  <!-- Experiencia docente -->
  <section class="section edu-teaching">
    <div class="container">
      <h2 class="section-title animate">{t('education.teaching_title')}</h2>
      <div class="divider animate animate--delay-1"></div>
      <p class="edu-teaching__intro animate animate--delay-2">{t('education.teaching_intro')}</p>

      <div class="edu-teaching__list">
        {teaching.map((item: any, i: number) => (
          <article class={`edu-teaching__item animate animate--delay-${Math.min(i + 1, 5)}`}>
            <span class="edu-teaching__year">{item.year}</span>
            <div class="edu-teaching__content">
              <h3 class="edu-teaching__event">{item.event}</h3>
              <p class="edu-teaching__inst">{item.institution}</p>
              <p class="edu-teaching__topic">"{item.topic}"</p>
            </div>
            {item.logo && (
              <div class="edu-teaching__logo">
                <img src={item.logo.src} alt={item.logo.alt} loading="lazy" />
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Instituciones colaboradoras -->
  <section class="section edu-institutions">
    <div class="container">
      <h2 class="section-title animate">{t('education.institutions_title')}</h2>
      <div class="divider animate animate--delay-1"></div>
      <div class="edu-institutions__grid">
        {institutions.map((inst, i) => (
          <a
            href={inst.url}
            target="_blank"
            rel="noopener"
            class={`edu-institutions__card animate animate--delay-${i + 1}`}
            aria-label={inst.name}
          >
            <div class="edu-institutions__logo-wrap">
              <img
                src={inst.logo}
                alt={inst.name}
                width="180"
                height="80"
                loading="lazy"
                class="edu-institutions__logo"
                onerror="this.closest('.edu-institutions__logo-wrap').style.display='none'"
              />
            </div>
            <span class="edu-institutions__name">{inst.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Galería formación -->
  <section class="section edu-gallery">
    <div class="container">
      <h2 class="section-title animate">{t('education.gallery_title')}</h2>
      <div class="divider animate animate--delay-1"></div>
      <div
        x-data="{ lightbox: false, src: '', alt: '', idx: 0, photos: [] }"
        x-init={`photos = ${JSON.stringify(formacionPhotos)}`}
        @keydown.escape.window="lightbox = false"
      >
        <div class="edu-gallery__grid">
          {formacionPhotos.map((photo, i) => (
            <button
              class="edu-gallery__item animate"
              style={`animation-delay: ${(i % 5) * 0.05}s`}
              @click={`lightbox = true; src = '${photo.src}'; alt = '${photo.alt}'; idx = ${i}`}
              aria-label={photo.alt}
            >
              <img
                src={photo.src}
                alt={photo.alt}
                width="400"
                height="300"
                loading="lazy"
                class="edu-gallery__img"
                onerror="this.closest('button').style.display='none'"
              />
              <div class="edu-gallery__overlay" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                  <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
                </svg>
              </div>
            </button>
          ))}
        </div>

        <div
          class="lightbox"
          x-show="lightbox"
          x-transition:enter="lightbox-enter"
          x-transition:enter-start="lightbox-enter-start"
          x-transition:enter-end="lightbox-enter-end"
          x-transition:leave="lightbox-leave"
          x-transition:leave-start="lightbox-leave-start"
          x-transition:leave-end="lightbox-leave-end"
          @click.self="lightbox = false"
          role="dialog"
          aria-modal="true"
          :aria-label="alt"
        >
          <button class="lightbox__close" @click="lightbox = false" aria-label="Cerrar">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
          <button class="lightbox__nav lightbox__nav--prev"
            @click="idx = (idx - 1 + photos.length) % photos.length; src = photos[idx].src; alt = photos[idx].alt"
            aria-label="Anterior">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>
          <img :src="src" :alt="alt" class="lightbox__img" width="1200" height="800" />
          <button class="lightbox__nav lightbox__nav--next"
            @click="idx = (idx + 1) % photos.length; src = photos[idx].src; alt = photos[idx].alt"
            aria-label="Siguiente">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
          <p class="lightbox__caption" x-text="alt"></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-hero {
  position: relative;
  min-height: 400px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
.page-hero__bg { position: absolute; inset: 0; }
.page-hero__img { width: 100%; height: 100%; object-fit: cover; object-position: center 25%; }
.page-hero__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(0deg, rgba(10,10,10,1) 0%, rgba(10,10,10,0.7) 100%);
}
.page-hero__content { position: relative; z-index: 1; padding-bottom: var(--space-12); }
.page-hero__title {
  font-family: var(--font-display);
  font-size: var(--text-5xl);
  color: var(--white);
  line-height: 1;
}
.page-hero__title span { color: var(--lime); }

/* Teaching */
.edu-teaching { background: var(--black-soft); }
.edu-teaching__intro {
  font-size: var(--text-base);
  color: var(--gray-400);
  line-height: 1.8;
  max-width: 780px;
  margin-bottom: var(--space-10);
}
.edu-teaching__list {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}
.edu-teaching__item {
  display: flex;
  gap: var(--space-8);
  padding: var(--space-6);
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: var(--radius-lg);
  transition: border-color var(--transition-base);
  align-items: center;
}
.edu-teaching__item:hover { border-color: var(--lime); }
.edu-teaching__year {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  color: var(--lime);
  flex-shrink: 0;
  min-width: 4rem;
  line-height: 1;
}
.edu-teaching__content {
  flex: 1;
  min-width: 0;
}
.edu-teaching__event {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--white);
  margin-bottom: var(--space-1);
}
.edu-teaching__inst {
  font-size: var(--text-sm);
  color: var(--gray-500);
  margin-bottom: var(--space-2);
}
.edu-teaching__topic {
  font-size: var(--text-sm);
  color: var(--gray-400);
  font-style: italic;
}
.edu-teaching__logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 90px;
  min-height: 90px;
  background: #fff;
  border-radius: 10px;
  border: 1px solid var(--black-border);
  padding: 8px;
  transition: border-color var(--transition-base);
}
.edu-teaching__item:hover .edu-teaching__logo {
  border-color: rgba(163, 230, 53, 0.35);
}
.edu-teaching__logo img {
  max-height: 68px;
  max-width: 68px;
  object-fit: contain;
}

/* Institutions */
.edu-institutions { background: var(--black); }
.edu-institutions__grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-6);
  justify-content: center;
  align-items: center;
}
.edu-institutions__card {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: var(--radius-lg);
  padding: var(--space-5) var(--space-6);
  transition: all var(--transition-base);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-4);
  min-width: 160px;
  text-decoration: none;
}
.edu-institutions__card:hover {
  border-color: var(--lime);
  box-shadow: var(--shadow-lime);
}
.edu-institutions__logo-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 160px;
  height: 130px;
  background: #fff;
  border-radius: 10px;
  padding: 14px;
}
.edu-institutions__logo {
  max-width: 100%;
  max-height: 100px;
  object-fit: contain;
  transition: transform var(--transition-base);
}
.edu-institutions__card:hover .edu-institutions__logo {
  transform: scale(1.05);
}
.edu-institutions__name {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--gray-400);
  text-align: center;
  line-height: 1.4;
  transition: color var(--transition-base);
}
.edu-institutions__card:hover .edu-institutions__name {
  color: var(--lime);
}

/* Gallery */
.edu-gallery { background: var(--black-soft); }
.edu-gallery__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: var(--space-3);
}
.edu-gallery__item {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-md);
  aspect-ratio: 4/3;
  background: var(--black-card);
  cursor: pointer;
  border: none;
  padding: 0;
}
.edu-gallery__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  transition: transform var(--transition-slow);
}
.edu-gallery__item:hover .edu-gallery__img { transform: scale(1.05); }
.edu-gallery__overlay {
  position: absolute;
  inset: 0;
  background: rgba(163, 230, 53, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity var(--transition-base);
  color: var(--white);
}
.edu-gallery__item:hover .edu-gallery__overlay { opacity: 1; }
.lightbox {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.95);
  backdrop-filter: blur(8px);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-6);
}
.lightbox-enter { transition: opacity 0.25s ease; }
.lightbox-enter-start, .lightbox-leave-end { opacity: 0; }
.lightbox-enter-end, .lightbox-leave-start { opacity: 1; }
.lightbox-leave { transition: opacity 0.25s ease; }
.lightbox__img {
  max-width: 90vw;
  max-height: 85vh;
  object-fit: contain;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-img);
}
.lightbox__close {
  position: absolute;
  top: var(--space-5);
  right: var(--space-5);
  width: 44px;
  height: 44px;
  border-radius: var(--radius-full);
  background: var(--black-soft);
  border: 1px solid var(--black-border);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}
.lightbox__close:hover { background: var(--lime); color: var(--black); }
.lightbox__nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 48px;
  height: 48px;
  border-radius: var(--radius-full);
  background: var(--black-soft);
  border: 1px solid var(--black-border);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}
.lightbox__nav:hover { background: var(--lime); color: var(--black); }
.lightbox__nav--prev { left: var(--space-4); }
.lightbox__nav--next { right: var(--space-4); }
.lightbox__caption {
  position: absolute;
  bottom: var(--space-5);
  left: 50%;
  transform: translateX(-50%);
  font-size: var(--text-sm);
  color: var(--gray-400);
  text-align: center;
  max-width: 80%;
}

/* Responsive */
@media (max-width: 480px) {
  .edu-teaching__item { flex-direction: column; gap: var(--space-3); }
}
</style>
