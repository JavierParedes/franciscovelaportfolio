---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const academic = t('academic') as any[];
---

<BaseLayout
  lang={lang}
  currentPage="/en/education"
  title={t('education.meta_title') as string}
  description={t('education.meta_description') as string}
  image="/images/formacion/formacion-008.jpg"
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="/images/formacion/formacion-008.jpg" alt="" aria-hidden="true" width="1400" height="500" loading="eager" class="page-hero__img" />
      <div class="page-hero__overlay"></div>
    </div>
    <div class="container page-hero__content animate">
      <span class="section-tagline">{t('education.tagline')}</span>
      <h1 class="page-hero__title">
        ACADEMIC<br /><span>CURRICULUM</span>
      </h1>
    </div>
  </section>

  <!-- Academic qualifications -->
  <section class="section edu-academic">
    <div class="container">
      <div class="edu-academic__grid">
        {academic.map((item: any, i: number) => (
          <div class={`edu-academic__card animate animate--delay-${i + 1}`}>
            <div class="edu-academic__year-wrap">
              <span class="edu-academic__year">{item.year}</span>
              <span class="badge">{item.type}</span>
            </div>
            <h3 class="edu-academic__title">{item.title}</h3>
            <p class="edu-academic__inst">
              {Array.isArray(item.institution)
                ? item.institution.map((line: string, idx: number) => <>{idx > 0 && <br />}{line}</>)
                : item.institution}
            </p>
            {item.extra && <p class="edu-academic__extra">{item.extra}</p>}
            {item.logos && item.logos.length > 0 && (
              <div class={`card-logos card-logos--${item.logos.length === 1 ? 'single' : 'multi'}`}>
                {item.logos.map((logo: any) => (
                  <div class="card-logo">
                    <img src={logo.src} alt={logo.alt} loading="lazy" />
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- CV downloads -->
      <div class="edu-cv animate">
        <h3 class="edu-cv__title">{t('education.cv_title')}</h3>
        <div class="edu-cv__btns">
          <a href="/cv-francisco-vela-es.pdf" target="_blank" rel="noopener" class="btn btn--primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            {t('education.cv_es')}
          </a>
          <a href="/cv-francisco-vela-en.pdf" target="_blank" rel="noopener" class="btn btn--outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            {t('education.cv_en')}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-hero {
  position: relative;
  min-height: 400px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
.page-hero__bg { position: absolute; inset: 0; }
.page-hero__img { width: 100%; height: 100%; object-fit: cover; object-position: center 15%; }
.page-hero__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(0deg, rgba(10,10,10,1) 0%, rgba(10,10,10,0.7) 100%);
}
.page-hero__content { position: relative; z-index: 1; padding-bottom: var(--space-12); }
.page-hero__title {
  font-family: var(--font-display);
  font-size: var(--text-5xl);
  color: var(--white);
  line-height: 1;
}
.page-hero__title span { color: var(--lime); }

/* Academic */
.edu-academic__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-8);
  margin-bottom: var(--space-12);
}
.edu-academic__card {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  position: relative;
  transition: border-color var(--transition-base), transform var(--transition-base);
  display: flex;
  flex-direction: column;
}
.edu-academic__card:hover {
  border-color: var(--lime);
  transform: translateY(-4px);
}
.edu-academic__year-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-4);
}
.edu-academic__year {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  color: var(--lime);
  line-height: 1;
}
.edu-academic__title {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--white);
  line-height: 1.4;
  margin-bottom: var(--space-2);
}
.edu-academic__inst {
  font-size: var(--text-sm);
  color: var(--gray-500);
  margin-bottom: var(--space-2);
}
.edu-academic__extra {
  font-size: var(--text-sm);
  color: var(--gray-400);
  border-top: 1px solid var(--black-border);
  padding-top: var(--space-3);
  margin-top: var(--space-3);
  font-style: italic;
}

/* Card logos */
.card-logos {
  display: flex;
  align-items: stretch;
  gap: var(--space-3);
  margin-top: var(--space-5);
  margin-bottom: 0;
}
.card-logo {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10px 14px;
  min-height: 90px;
  background: #fff;
  border-radius: 10px;
  border: 1px solid var(--black-border);
  transition: border-color var(--transition-base);
}
.edu-academic__card:hover .card-logo {
  border-color: rgba(163, 230, 53, 0.35);
}
.card-logo img {
  max-height: 68px;
  max-width: 100%;
  object-fit: contain;
  transition: transform var(--transition-base);
}
.edu-academic__card:hover .card-logo img {
  transform: scale(1.05);
}

/* CV */
.edu-cv {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  text-align: center;
}
.edu-cv__title {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  color: var(--white);
  margin-bottom: var(--space-6);
}
.edu-cv__btns {
  display: flex;
  gap: var(--space-4);
  justify-content: center;
  flex-wrap: wrap;
}

@media (max-width: 480px) {
  .edu-cv__btns { flex-direction: column; }
}
</style>
