---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
const lang = 'en';
const t = useTranslations(lang);
const idata = t('interviews_data') as any;
---
<BaseLayout lang={lang} currentPage="/en/interviews" title={t('interviews.meta_title') as string} description={t('interviews.meta_description') as string}>
  <!-- Reuse same structure as ES version, just with EN translations -->
  <section class="page-hero">
    <div class="page-hero__bg"><img src="/images/llerenense/llerenense-051.jpg" alt="" aria-hidden="true" width="1400" height="500" loading="eager" class="page-hero__img" /><div class="page-hero__overlay"></div></div>
    <div class="container page-hero__content animate"><span class="section-tagline">{t('interviews.tagline')}</span><h1 class="page-hero__title">{t('interviews.title_1')}<br /><span>{t('interviews.title_2')}</span></h1></div>
  </section>
  <section class="section"><div class="container">
    <h2 class="section-title animate">{t('interviews.videos_title')}</h2><div class="divider animate animate--delay-1"></div>
    <div class="videos-grid">{idata.videos.map((v: any, i: number) => (<article class={`video-card animate animate--delay-${i+1}`}>{v.youtube_id !== 'PENDIENTE' ? (<div class="video-embed" x-data="{l:false}"><div class="video-thumb" x-show="!l" @click="l=true" style={`background-image:url('https://img.youtube.com/vi/${v.youtube_id}/maxresdefault.jpg')`}><div class="play-btn"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></div></div><iframe x-show="l" :src={`l?'https://www.youtube.com/embed/${v.youtube_id}?autoplay=1':''`} title={v.title} style="border:0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="video-iframe" loading="lazy"></iframe></div>) : (<div class="video-pending"><p>Video coming soon</p></div>)}<div class="video-info"><h3>{v.title}</h3><p>{v.description}</p></div></article>))}</div>
  </div></section>
  <section class="section bg-soft"><div class="container">
    <h2 class="section-title animate">{t('interviews.audio_title')}</h2><div class="divider animate animate--delay-1"></div>
    <div class="audio-list">{idata.audios.map((a: any, i: number) => (<div class={`ap animate animate--delay-${i+1}`} x-data=`{pl:false,pr:0,ct:0,dur:0,tg(){const au=this.$refs.au;this.pl?au.pause():au.play();this.pl=!this.pl},upd(){const au=this.$refs.au;this.ct=au.currentTime;this.pr=(au.currentTime/au.duration)*100||0},ini(){const au=this.$refs.au;au.addEventListener('loadedmetadata',()=>{this.dur=au.duration});au.addEventListener('durationchange',()=>{this.dur=au.duration});au.addEventListener('ended',()=>{this.pl=false;this.pr=0;this.ct=0})},sk(e){const au=this.$refs.au;const dur=au.duration||this.dur;if(!dur||isNaN(dur))return;const r=this.$refs.progressbar.getBoundingClientRect();const cx=e.touches?e.touches[0].clientX:e.clientX;au.currentTime=Math.min(1,Math.max(0,(cx-r.left)/r.width))*dur},fm(s){if(!s||isNaN(s))return'0:00';const m=Math.floor(s/60);return m+':'+(Math.floor(s%60)).toString().padStart(2,'0')}}`} x-init="ini()"><audio x-ref="au" @timeupdate="upd()" preload="metadata"><source src={a.file} type="audio/mp4" /></audio><div class="ap__head"><div class="ap__icon"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div><div><h3 class="ap__title">{a.title}</h3><p class="ap__sub">{a.subtitle}</p></div></div><div class="ap__ctrl"><button class="ap__play" @click="tg()" :aria-label="pl?'Pause':'Play'"><svg x-show="!pl" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg><svg x-show="pl" x-cloak xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg></button><div class="ap__bar-wrap"><div class="ap__bar" x-ref="progressbar" @click="sk($event)" @touchstart.prevent="sk($event)"><div class="ap__fill" :style="`width:${pr}%`"></div></div><div class="ap__times"><span x-text="fm(ct)">0:00</span><span x-text="fm(dur)">0:00</span></div></div></div></div>))}</div>
  </div></section>
  <section class="section"><div class="container">
    <h2 class="section-title animate">{t('interviews.written_title')}</h2><div class="divider animate animate--delay-1"></div>
    <div class="written-list">{idata.written.map((art: any, i: number) => (<a href={art.url} target="_blank" rel="noopener noreferrer" class={`written-card animate animate--delay-${i+1}`}><div class="written-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div><div><span class="written-media">{art.media}</span><h3 class="written-title">{art.title}</h3><p class="written-desc">{art.description}</p><span class="written-link">Read full interview →</span></div></a>))}</div>
  </div></section>
</BaseLayout>

<style>
.page-hero{position:relative;min-height:400px;display:flex;align-items:flex-end;overflow:hidden}.page-hero__bg{position:absolute;inset:0}.page-hero__img{width:100%;height:100%;object-fit:cover;object-position:center 35%}.page-hero__overlay{position:absolute;inset:0;background:linear-gradient(0deg,rgba(10,10,10,1) 0%,rgba(10,10,10,.7) 100%)}.page-hero__content{position:relative;z-index:1;padding-bottom:var(--space-12)}.page-hero__title{font-family:var(--font-display);font-size:var(--text-5xl);color:var(--white);line-height:1}.page-hero__title span{color:var(--lime)}.bg-soft{background:var(--black-soft)}.videos-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:var(--space-6)}.video-card{background:var(--black-card);border:1px solid var(--black-border);border-radius:var(--radius-lg);overflow:hidden;transition:border-color var(--transition-base)}.video-card:hover{border-color:var(--lime)}.video-embed{position:relative;aspect-ratio:16/9;overflow:hidden;background:var(--black)}.video-thumb{position:absolute;inset:0;background-size:cover;background-position:center;cursor:pointer;display:flex;align-items:center;justify-content:center}.play-btn{width:64px;height:64px;border-radius:var(--radius-full);background:var(--lime);display:flex;align-items:center;justify-content:center;color:var(--black);padding-left:4px;transition:transform var(--transition-fast)}.video-thumb:hover .play-btn{transform:scale(1.1)}.video-iframe{width:100%;height:100%;position:absolute;inset:0}.video-pending{aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;color:var(--gray-600);font-size:var(--text-sm)}.video-info{padding:var(--space-5)}.video-info h3{font-size:var(--text-base);font-weight:700;color:var(--white);margin-bottom:var(--space-2)}.video-info p{font-size:var(--text-sm);color:var(--gray-500)}.audio-list{display:flex;flex-direction:column;gap:var(--space-5)}.ap{background:var(--black-card);border:1px solid var(--black-border);border-radius:var(--radius-lg);padding:var(--space-6);transition:border-color var(--transition-base)}.ap:hover{border-color:var(--lime)}.ap__head{display:flex;gap:var(--space-5);margin-bottom:var(--space-6)}.ap__icon{width:56px;height:56px;border-radius:var(--radius-md);background:var(--lime-glow);border:1px solid var(--lime);display:flex;align-items:center;justify-content:center;color:var(--lime);flex-shrink:0}.ap__title{font-size:var(--text-base);font-weight:700;color:var(--white);margin-bottom:2px}.ap__sub{font-size:var(--text-xs);color:var(--lime);font-weight:600}.ap__ctrl{display:flex;align-items:center;gap:var(--space-4)}.ap__play{width:48px;height:48px;flex-shrink:0;border-radius:var(--radius-full);background:var(--lime);color:var(--black);display:flex;align-items:center;justify-content:center;transition:all var(--transition-fast);padding-left:2px}.ap__play:hover{background:var(--lime-bright);transform:scale(1.05)}.ap__bar-wrap{flex:1}.ap__bar{position:relative;height:6px;background:var(--black-border);border-radius:var(--radius-full);cursor:pointer;margin-bottom:var(--space-2)}.ap__fill{height:100%;background:var(--lime);border-radius:var(--radius-full);transition:width .1s linear;pointer-events:none}.ap__times{display:flex;justify-content:space-between;font-size:var(--text-xs);color:var(--gray-600)}.written-list{display:flex;flex-direction:column;gap:var(--space-4)}.written-card{display:flex;gap:var(--space-5);padding:var(--space-6);background:var(--black-card);border:1px solid var(--black-border);border-radius:var(--radius-lg);transition:all var(--transition-base)}.written-card:hover{border-color:var(--lime);transform:translateX(4px)}.written-icon{width:48px;height:48px;flex-shrink:0;border-radius:var(--radius-md);background:var(--lime-glow);display:flex;align-items:center;justify-content:center;color:var(--lime)}.written-media{display:block;font-size:var(--text-xs);font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--lime);margin-bottom:var(--space-1)}.written-title{font-size:var(--text-base);font-weight:700;color:var(--white);line-height:1.4;margin-bottom:var(--space-2)}.written-desc{font-size:var(--text-sm);color:var(--gray-500);margin-bottom:var(--space-3)}.written-link{font-size:var(--text-sm);font-weight:600;color:var(--lime)}[x-cloak]{display:none!important}
</style>
