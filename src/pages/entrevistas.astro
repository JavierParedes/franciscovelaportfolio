---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
const idata = t('interviews_data') as any;
---

<BaseLayout
  lang={lang}
  currentPage="/entrevistas"
  title={t('interviews.meta_title') as string}
  description={t('interviews.meta_description') as string}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="page-hero__bg">
      <img src="/images/llerenense/llerenense-051.jpg" alt="" aria-hidden="true" width="1400" height="500" loading="eager" class="page-hero__img" />
      <div class="page-hero__overlay"></div>
    </div>
    <div class="container page-hero__content animate">
      <span class="section-tagline">{t('interviews.tagline')}</span>
      <h1 class="page-hero__title">
        {t('interviews.title_1')}<br /><span>{t('interviews.title_2')}</span>
      </h1>
    </div>
  </section>

  <!-- Vídeos -->
  <section class="section int-videos">
    <div class="container">
      <h2 class="section-title animate">{t('interviews.videos_title')}</h2>
      <div class="divider animate animate--delay-1"></div>
      <div class="int-videos__grid">
        {idata.videos.map((video: any, i: number) => (
          <article class={`int-video-card animate animate--delay-${i + 1}`}>
            {video.youtube_id !== 'PENDIENTE' ? (
              <div
                class="int-video-card__embed-wrapper"
                x-data="{ loaded: false }"
              >
                <div
                  class="int-video-card__thumb"
                  x-show="!loaded"
                  @click="loaded = true"
                  style={`background-image: url('${video.thumbnail || `https://img.youtube.com/vi/${video.youtube_id}/maxresdefault.jpg`}')`}
                  role="button"
                  tabindex="0"
                  aria-label={`Reproducir: ${video.title}`}
                  @keydown.enter="loaded = true"
                >
                  <div class="int-video-card__play-btn" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                      <polygon points="5 3 19 12 5 21 5 3"/>
                    </svg>
                  </div>
                </div>
                <iframe
                  x-show="loaded"
                  :src={`loaded ? 'https://www.youtube.com/embed/${video.youtube_id}?autoplay=1' : ''`}
                  title={video.title}
                  style="border:0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="int-video-card__iframe"
                  loading="lazy"
                ></iframe>
              </div>
            ) : (
              <div class="int-video-card__pending">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
                <p>Vídeo próximamente disponible</p>
              </div>
            )}
            <div class="int-video-card__info">
              <h3 class="int-video-card__title">{video.title}</h3>
              <p class="int-video-card__desc">{video.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Audio -->
  <section class="section int-audio">
    <div class="container">
      <h2 class="section-title animate">{t('interviews.audio_title')}</h2>
      <div class="divider animate animate--delay-1"></div>
      <div class="int-audio__list">
        {idata.audios.map((audio: any, i: number) => (
          <div
            class={`audio-player animate animate--delay-${i + 1}`}
            x-data={`{
              playing: false,
              progress: 0,
              currentTime: 0,
              duration: 0,
              volume: 1,
              toggle() {
                const a = this.$refs.audio;
                this.playing ? a.pause() : a.play();
                this.playing = !this.playing;
              },
              update() {
                const a = this.$refs.audio;
                this.currentTime = a.currentTime;
                this.progress = (a.currentTime / a.duration) * 100 || 0;
              },
              init_audio() {
                const a = this.$refs.audio;
                a.addEventListener('loadedmetadata', () => { this.duration = a.duration; });
                a.addEventListener('durationchange', () => { this.duration = a.duration; });
                a.addEventListener('ended', () => { this.playing = false; this.progress = 0; this.currentTime = 0; });
              },
              seek(e) {
                const a = this.$refs.audio;
                const dur = a.duration || this.duration;
                if (!dur || isNaN(dur)) return;
                const rect = this.$refs.progressbar.getBoundingClientRect();
                const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                const pct = Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
                a.currentTime = pct * dur;
              },
              fmt(s) {
                if (!s || isNaN(s)) return '0:00';
                const m = Math.floor(s / 60);
                const sec = Math.floor(s % 60).toString().padStart(2, '0');
                return m + ':' + sec;
              }
            }`}
            x-init="init_audio()"
          >
            <audio x-ref="audio" @timeupdate="update()" preload="metadata">
              <source src={audio.file} type="audio/mp4" />
            </audio>

            <div class="audio-player__header">
              <div class="audio-player__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
                </svg>
              </div>
              <div class="audio-player__meta">
                <h3 class="audio-player__title">{audio.title}</h3>
                <p class="audio-player__subtitle">{audio.subtitle}</p>
                <p class="audio-player__desc">{audio.description}</p>
              </div>
            </div>

            <!-- Controles -->
            <div class="audio-player__controls">
              <button
                class="audio-player__play-btn"
                @click="toggle()"
                :aria-label="playing ? 'Pausar' : 'Reproducir'"
              >
                <svg x-show="!playing" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
                <svg x-show="playing" x-cloak xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>
                </svg>
              </button>

              <!-- Barra de progreso -->
              <div class="audio-player__progress-wrap">
                <div
                  class="audio-player__progress-bar"
                  x-ref="progressbar"
                  @click="seek($event)"
                  @touchstart.prevent="seek($event)"
                  role="slider"
                  :aria-valuenow="Math.round(progress)"
                  aria-valuemin="0"
                  aria-valuemax="100"
                  aria-label="Progreso de reproducción"
                >
                  <div
                    class="audio-player__progress-fill"
                    :style="`width: ${progress}%`"
                    :class="playing && 'is-playing'"
                  ></div>
                  <div
                    class="audio-player__progress-thumb"
                    :style="`left: ${progress}%`"
                  ></div>
                </div>
                <div class="audio-player__times">
                  <span x-text="fmt(currentTime)">0:00</span>
                  <span x-text="fmt(duration)">0:00</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Prensa escrita -->
  <section class="section int-written">
    <div class="container">
      <h2 class="section-title animate">{t('interviews.written_title')}</h2>
      <div class="divider animate animate--delay-1"></div>
      <div class="int-written__list">
        {idata.written.map((art: any, i: number) => (
          <a
            href={art.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`int-written__card animate animate--delay-${i + 1}`}
          >
            <div class="int-written__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </div>
            <div class="int-written__content">
              <span class="int-written__media">{art.media}</span>
              <h3 class="int-written__title">{art.title}</h3>
              <p class="int-written__desc">{art.description}</p>
              <span class="int-written__link">
                Leer entrevista completa
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.page-hero {
  position: relative; min-height: 400px;
  display: flex; align-items: flex-end; overflow: hidden;
}
.page-hero__bg { position: absolute; inset: 0; }
.page-hero__img { width: 100%; height: 100%; object-fit: cover; object-position: center 35%; }
.page-hero__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(0deg, rgba(10,10,10,1) 0%, rgba(10,10,10,0.7) 100%);
}
.page-hero__content { position: relative; z-index: 1; padding-bottom: var(--space-12); }
.page-hero__title { font-family: var(--font-display); font-size: var(--text-5xl); color: var(--white); line-height: 1; }
.page-hero__title span { color: var(--lime); }

/* Vídeos */
.int-videos__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--space-6);
}

.int-video-card {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: border-color var(--transition-base);
}
.int-video-card:hover { border-color: var(--lime); }

.int-video-card__embed-wrapper {
  position: relative;
  aspect-ratio: 16/9;
  overflow: hidden;
  background: var(--black);
}
.int-video-card__thumb {
  position: absolute; inset: 0;
  background-size: cover;
  background-position: center;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}
.int-video-card__play-btn {
  width: 64px; height: 64px;
  border-radius: var(--radius-full);
  background: var(--lime);
  display: flex; align-items: center; justify-content: center;
  color: var(--black);
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  padding-left: 4px;
}
.int-video-card__thumb:hover .int-video-card__play-btn {
  transform: scale(1.1);
  box-shadow: var(--shadow-lime);
}
.int-video-card__iframe {
  width: 100%; height: 100%;
  position: absolute; inset: 0;
}
.int-video-card__pending {
  aspect-ratio: 16/9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
  color: var(--gray-600);
  background: var(--black-card);
  font-size: var(--text-sm);
}
.int-video-card__info { padding: var(--space-5); }
.int-video-card__title { font-size: var(--text-base); font-weight: 700; color: var(--white); margin-bottom: var(--space-2); }
.int-video-card__desc { font-size: var(--text-sm); color: var(--gray-500); }

/* Audio player */
.int-audio { background: var(--black-soft); }
.int-audio__list { display: flex; flex-direction: column; gap: var(--space-5); }

.audio-player {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  transition: border-color var(--transition-base);
}
.audio-player:hover { border-color: var(--lime); }

.audio-player__header {
  display: flex;
  gap: var(--space-5);
  margin-bottom: var(--space-6);
}
.audio-player__icon {
  width: 56px; height: 56px;
  border-radius: var(--radius-md);
  background: var(--lime-glow);
  border: 1px solid var(--lime);
  display: flex; align-items: center; justify-content: center;
  color: var(--lime);
  flex-shrink: 0;
}
.audio-player__title { font-size: var(--text-base); font-weight: 700; color: var(--white); margin-bottom: 2px; }
.audio-player__subtitle { font-size: var(--text-xs); color: var(--lime); font-weight: 600; letter-spacing: 0.05em; margin-bottom: var(--space-1); }
.audio-player__desc { font-size: var(--text-sm); color: var(--gray-500); }

.audio-player__controls {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.audio-player__play-btn {
  width: 48px; height: 48px; flex-shrink: 0;
  border-radius: var(--radius-full);
  background: var(--lime);
  color: var(--black);
  display: flex; align-items: center; justify-content: center;
  transition: all var(--transition-fast);
  padding-left: 2px;
}
.audio-player__play-btn:hover {
  background: var(--lime-bright);
  transform: scale(1.05);
  box-shadow: var(--shadow-lime);
}

.audio-player__progress-wrap { flex: 1; }

.audio-player__progress-bar {
  position: relative;
  height: 6px;
  background: var(--black-border);
  border-radius: var(--radius-full);
  cursor: pointer;
  margin-bottom: var(--space-2);
}
.audio-player__progress-fill {
  height: 100%;
  background: var(--lime);
  border-radius: var(--radius-full);
  transition: width 0.1s linear;
  position: relative;
  pointer-events: none;
}
.audio-player__progress-fill.is-playing {
  box-shadow: 0 0 8px rgba(163, 230, 53, 0.5);
}
.audio-player__progress-thumb {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 14px; height: 14px;
  border-radius: var(--radius-full);
  background: var(--lime);
  border: 2px solid var(--black);
  box-shadow: 0 0 6px rgba(163, 230, 53, 0.4);
  transition: left 0.1s linear;
  pointer-events: none;
}

.audio-player__times {
  display: flex;
  justify-content: space-between;
  font-size: var(--text-xs);
  color: var(--gray-600);
  font-variant-numeric: tabular-nums;
}

/* Written */
.int-written__list { display: flex; flex-direction: column; gap: var(--space-4); }
.int-written__card {
  display: flex;
  gap: var(--space-5);
  padding: var(--space-6);
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: var(--radius-lg);
  transition: all var(--transition-base);
}
.int-written__card:hover {
  border-color: var(--lime);
  transform: translateX(4px);
}
.int-written__icon {
  width: 48px; height: 48px; flex-shrink: 0;
  border-radius: var(--radius-md);
  background: var(--lime-glow);
  display: flex; align-items: center; justify-content: center;
  color: var(--lime);
}
.int-written__media { display: block; font-size: var(--text-xs); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--lime); margin-bottom: var(--space-1); }
.int-written__title { font-size: var(--text-base); font-weight: 700; color: var(--white); line-height: 1.4; margin-bottom: var(--space-2); }
.int-written__desc { font-size: var(--text-sm); color: var(--gray-500); margin-bottom: var(--space-3); }
.int-written__link {
  display: inline-flex; align-items: center; gap: var(--space-1);
  font-size: var(--text-sm); font-weight: 600; color: var(--lime);
  transition: gap var(--transition-fast);
}
.int-written__card:hover .int-written__link { gap: var(--space-2); }

[x-cloak] { display: none !important; }

@media (max-width: 480px) {
  .audio-player__header { flex-direction: column; }
  .int-written__card { flex-direction: column; }
  .int-videos__grid { grid-template-columns: 1fr; }
}
</style>
