---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
---

<BaseLayout
  lang={lang}
  currentPage="/contacto"
  title={t('contact.meta_title') as string}
  description={t('contact.meta_description') as string}
>
  <section class="contact-page section">
    <div class="container contact-page__inner">
      <!-- Info -->
      <div class="contact-info animate">
        <span class="section-tagline">{t('contact.tagline')}</span>
        <h1 class="contact-info__title">
          {t('contact.title_1')}<br />
          <span>{t('contact.title_2') || 'CONECTEMOS'}</span>
        </h1>
        <div class="divider"></div>
        <p class="contact-info__subtitle">{t('contact.subtitle')}</p>

        <div class="contact-info__items">
          <a href={`mailto:${t('contact.info_email')}`} class="contact-info__item">
            <div class="contact-info__item-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <span class="contact-info__item-label">Email</span>
              <span class="contact-info__item-val">{t('contact.info_email')}</span>
            </div>
          </a>

          <a href="https://www.instagram.com/franciscovelapf" target="_blank" rel="noopener" class="contact-info__item">
            <div class="contact-info__item-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </div>
            <div>
              <span class="contact-info__item-label">Instagram</span>
              <span class="contact-info__item-val">{t('contact.info_instagram')}</span>
            </div>
          </a>

          <a href="https://www.tiktok.com/@franciscovelapf" target="_blank" rel="noopener" class="contact-info__item">
            <div class="contact-info__item-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.07a8.16 8.16 0 004.77 1.52V7.13a4.85 4.85 0 01-1-.44z"/>
              </svg>
            </div>
            <div>
              <span class="contact-info__item-label">TikTok</span>
              <span class="contact-info__item-val">{t('contact.info_tiktok')}</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Formulario -->
      <div
        class="contact-form animate animate--right"
        x-data="{
          submitted: false,
          error: false,
          loading: false,
          async submit(e) {
            this.loading = true;
            const data = new FormData(e.target);
            try {
              const r = await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(data).toString() });
              if (r.ok) { this.submitted = true; e.target.reset(); }
              else { this.error = true; }
            } catch { this.error = true; }
            this.loading = false;
          }
        }"
      >
        <!-- Éxito -->
        <div class="contact-form__success" x-show="submitted" x-cloak>
          <div class="contact-form__success-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h3>{t('contact.form_success')}</h3>
        </div>

        <form
          name="contacto"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          @submit.prevent="submit($event)"
          x-show="!submitted"
          class="contact-form__form"
          novalidate
        >
          <input type="hidden" name="form-name" value="contacto" />
          <p class="sr-only">
            <label>No rellenar si eres humano: <input name="bot-field" /></label>
          </p>

          <div class="form-row">
            <div class="form-field">
              <label class="form-label" for="nombre">{t('contact.form_name')} *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-input"
                required
                autocomplete="name"
                placeholder="Tu nombre completo"
              />
            </div>
            <div class="form-field">
              <label class="form-label" for="email">{t('contact.form_email')} *</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                required
                autocomplete="email"
                placeholder="tu@email.com"
              />
            </div>
          </div>

          <div class="form-field">
            <label class="form-label" for="asunto">{t('contact.form_subject')} *</label>
            <input
              type="text"
              id="asunto"
              name="asunto"
              class="form-input"
              required
              placeholder="Motivo del contacto"
            />
          </div>

          <div class="form-field">
            <label class="form-label" for="mensaje">{t('contact.form_message')} *</label>
            <textarea
              id="mensaje"
              name="mensaje"
              class="form-textarea"
              rows="5"
              required
              placeholder="Cuéntame cómo puedo ayudarte..."
            ></textarea>
          </div>

          <div x-show="error" x-cloak class="form-error-msg" role="alert">
            {t('contact.form_error')}
          </div>

          <button
            type="submit"
            class="btn btn--primary form-submit"
            :disabled="loading"
            :class="loading && 'is-loading'"
          >
            <span x-show="!loading">{t('contact.form_submit')}</span>
            <span x-show="loading" x-cloak>Enviando...</span>
            <svg x-show="!loading" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.contact-page {
  min-height: calc(100svh - var(--preheader-h) - var(--header-h));
  display: flex;
  align-items: center;
}
.contact-page__inner {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: clamp(var(--space-10), 6vw, var(--space-20));
  align-items: start;
  padding-block: var(--space-20);
}

/* Info */
.contact-info__title {
  font-family: var(--font-display);
  font-size: var(--text-5xl);
  color: var(--white);
  line-height: 1;
  margin-bottom: var(--space-4);
}
.contact-info__title span { color: var(--lime); }

.contact-info__subtitle {
  font-size: var(--text-base);
  color: var(--gray-400);
  line-height: 1.75;
  margin-bottom: var(--space-10);
}

.contact-info__items {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.contact-info__item {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-4);
  border-radius: var(--radius-md);
  border: 1px solid var(--black-border);
  transition: all var(--transition-fast);
}
.contact-info__item:hover {
  border-color: var(--lime);
  background: var(--lime-glow);
}
.contact-info__item-icon {
  width: 44px; height: 44px;
  border-radius: var(--radius-md);
  background: var(--lime-glow);
  border: 1px solid var(--lime);
  display: flex; align-items: center; justify-content: center;
  color: var(--lime);
  flex-shrink: 0;
}
.contact-info__item-label {
  display: block;
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray-600);
  margin-bottom: 2px;
}
.contact-info__item-val {
  display: block;
  font-size: var(--text-sm);
  color: var(--white);
  font-weight: 500;
}

/* Form */
.contact-form {
  background: var(--black-card);
  border: 1px solid var(--black-border);
  border-radius: var(--radius-lg);
  padding: clamp(var(--space-6), 4vw, var(--space-10));
}

.contact-form__success {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-4);
  padding: var(--space-12) 0;
}
.contact-form__success-icon {
  width: 64px; height: 64px;
  border-radius: var(--radius-full);
  background: var(--lime-glow);
  border: 2px solid var(--lime);
  display: flex; align-items: center; justify-content: center;
  color: var(--lime);
}
.contact-form__success h3 {
  font-size: var(--text-lg);
  color: var(--white);
}

.contact-form__form {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}

.form-field { display: flex; flex-direction: column; gap: var(--space-2); }

.form-label {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gray-400);
}

.form-input, .form-textarea {
  background: var(--black);
  border: 1.5px solid var(--black-border);
  border-radius: var(--radius-md);
  padding: 0.75rem 1rem;
  color: var(--white);
  font-size: var(--text-base);
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  width: 100%;
}
.form-input::placeholder, .form-textarea::placeholder { color: var(--gray-700); }
.form-input:focus, .form-textarea:focus {
  border-color: var(--lime);
  box-shadow: 0 0 0 3px var(--lime-glow);
  outline: none;
}
.form-textarea { resize: vertical; min-height: 120px; }

.form-error-msg {
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: var(--radius-md);
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-sm);
  color: #FCA5A5;
}

.form-submit {
  align-self: flex-start;
  padding: 0.875rem 2rem;
  font-size: var(--text-sm);
}
.form-submit:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: none !important;
}

[x-cloak] { display: none !important; }

/* Responsive */
@media (max-width: 768px) {
  .contact-page__inner { grid-template-columns: 1fr; gap: var(--space-10); }
  .form-row { grid-template-columns: 1fr; }
  .form-submit { align-self: stretch; justify-content: center; }
}
</style>
